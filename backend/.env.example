# Copy to ".env" in this folder (or use a ".env" at the repository root).
# See src/env_bootstrap.py — backend/.env is loaded first, then repo-root .env.

# Required
GROQ_API_KEY=
TAVILY_API_KEY=

# Optional (defaults shown in code / README)
# GROQ_MODEL=llama-3.1-8b-instant
# TAVILY_MAX_RESULTS=5
# LANGGRAPH_THREAD_ID=default
# LOG_LEVEL=INFO

# Alternate Groq key name (supported)
# groqAPIKey=
